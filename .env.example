# === Database ===
DATABASE_PATH=./data/finance.db
DATABASE_URL=./data/finance.db

# === Authentication (REQUIRED — generate with: openssl rand -base64 32) ===
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=your-auth-secret-here

# === Encryption (REQUIRED — for API key encryption) ===
ENCRYPTION_KEY=your-32-char-encryption-key

# === Admin credentials (first run) ===
MASTER_USERNAME=admin
MASTER_PASSWORD=your-strong-password-here

# === Host port (change if 3000 conflicts with other projects) ===
# APP_PORT=8082

# === Network ===
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Explorer API keys (EVM networks)
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
SNOWTRACE_API_KEY=
POLYGONSCAN_API_KEY=
BASESCAN_API_KEY=
ARBISCAN_API_KEY=
OPTIMISM_API_KEY=
FANTOM_API_KEY=
CRONOS_API_KEY=
AURORA_API_KEY=
MOONBEAM_API_KEY=
GNOSIS_API_KEY=

# Non-EVM
HELIUS_API_KEY=
TONCENTER_API_KEY=
